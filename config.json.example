{
  "target_device_user_id": "YOUR_CAMERA_USER_ID",
  "use_external_trigger": true,
  "trigger_source": "Line0",
  "trigger_activation": "RisingEdge",
  "pixel_format": "Mono8",
  "frame_width": 748,
  "frame_height": 700,
  "roi_offset_x": 248,
  "roi_offset_y": 1000,
  "exposure_time_us": 20000,
  "gain_db": 5,
  "max_parallel_frames": 5,
  "save_directory": "data/captured",
  "save_format": "JPEG",
  "jpeg_quality": 90,
  "auto_exposure": false,
  "auto_gain": false,
  "white_balance_auto": false,
  "roi_enable": true,
  "wb_red_ratio": 1.5,
  "wb_green_ratio": 1,
  "wb_blue_ratio": 1.8,
  "target_force_ip": "169.254.0.10",
  "target_force_subnet": "255.255.255.0",
  "target_force_gateway": "169.254.0.1",
  "enable_template_matching": false,
  "enable_patchcore": true,
  "patchcore_model_path": "models/model.ckpt",
  "patchcore_threshold": 0.5
}
